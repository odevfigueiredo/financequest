# Detectar arquivos de texto automaticamente e normalizar para LF
* text=auto eol=lf

# Gerenciadores de pacotes
package-lock.json linguist-generated=true
yarn.lock linguist-generated=true
pnpm-lock.yaml linguist-generated=true

# Arquivos-fonte
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.mjs text eol=lf
*.json text eol=lf
*.html text eol=lf
*.css text eol=lf

# Documentação
*.md text eol=lf
*.mdx text eol=lf

# Scripts de build e configurações
*.sh text eol=lf
.env* text eol=lf
.gitignore text eol=lf
.gitattributes text eol=lf

# Arquivos binários
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.svg text eol=lf
*.ico binary
*.pdf binary
*.mp4 binary
*.mp3 binary
*.wav binary

# Fontes
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary